{
  "name": "docplaybook-workspace",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter docplaybook test",
    "dev": "pnpm --filter docplaybook dev",
    "docs:dev": "pnpm --filter @docplaybook/docs dev",
    "docs:build": "pnpm --filter @docplaybook/docs build",
    "docs:preview": "pnpm --filter @docplaybook/docs preview"
  }
}
