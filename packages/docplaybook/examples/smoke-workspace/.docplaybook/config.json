{
  "version": 1,
  "sourceLanguage": "zh-CN",
  "targetLanguages": ["en"],
  "ignorePatterns": ["**/node_modules/**", "**/.git/**", "**/dist/**", "**/.docplaybook/**"],
  "concurrency": {
    "maxConcurrentRequests": 2
  },
  "batch": {
    "maxBlocksPerBatch": 4,
    "maxCharsPerBatch": 2000
  },
  "layout": {
    "kind": "sibling"
  },
  "model": {
    "kind": "openai",
    "model": "gpt-5-mini",
    "apiKeyEnv": "OPENAI_API_KEY"
  }
}
