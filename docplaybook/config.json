{
  "version": 1,
  "provider": {
    "kind": "local"
  },
  "sourceLanguage": "zh-CN",
  "targetLanguages": [
    "en",
    "ja"
  ],
  "layout": {
    "kind": "sibling"
  },
  "model": {
    "kind": "gateway",
    "model": "openai/gpt-5-mini",
    "apiKeyEnv": "AI_GATEWAY_API_KEY"
  },
  "watch": {
    "ignore": [
      "**/node_modules/**",
      "**/.git/**",
      "**/dist/**",
      "**/docplaybook/**",
      "**/translator-agent/**"
    ]
  }
}
